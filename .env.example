# SMTP credentials for the contact form (Nodemailer)
# Skrzynka, z której wysyłamy zgłoszenia i auto-odpowiedzi.
SMTP_HOST=smtp.your-provider.tld
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@wielkiformat.pl
SMTP_PASS=__set_in_hosting_env__

# Adres "From" widoczny dla klienta i odbiorca zgłoszeń (zwykle ten sam).
CONTACT_FROM="Wielkiformat.pl <info@wielkiformat.pl>"
CONTACT_TO=info@wielkiformat.pl

# Tymczasowe przełączniki publikacji.
# false/puste = pokazujemy stronę informacyjną z noindex.
# true = pokazujemy realną mapę/galerię i dodajemy ją do sitemapy.
SHOW_REAL_CARRIERS_PAGE=false
SHOW_REAL_GALLERY_PAGE=false
